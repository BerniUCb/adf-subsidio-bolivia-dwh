{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-subsidio-bolivia-dwh"
		},
		"LS_BlobStorage_connectionString": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"connectionString\"de \"LS_BlobStorage\""
		},
		"LS_Destino_DWH_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"LS_Destino_DWH\""
		},
		"LS_Destino_DWH_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "server-subsidio-bolivia-dwh.database.windows.net"
		},
		"LS_Destino_DWH_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dw-subsidio-bolivia"
		},
		"LS_Destino_DWH_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminsubsidio"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/LS_BlobStorage')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"connectionString": "[parameters('LS_BlobStorage_connectionString')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/LS_Destino_DWH')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('LS_Destino_DWH_properties_typeProperties_server')]",
					"database": "[parameters('LS_Destino_DWH_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('LS_Destino_DWH_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('LS_Destino_DWH_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_bronce')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"linkedService": {
								"referenceName": "LS_BlobStorage",
								"type": "LinkedServiceReference"
							},
							"name": "sourceSegipPersonas"
						}
					],
					"sinks": [
						{
							"linkedService": {
								"referenceName": "LS_Destino_DWH",
								"type": "LinkedServiceReference"
							},
							"name": "sinkSegipPersonas"
						}
					],
					"transformations": [],
					"scriptLines": [
						"source(output(",
						"          ci as string,",
						"          nombres as string,",
						"          ap_paterno as string,",
						"          ap_materno as string,",
						"          fecha_nacimiento as date,",
						"          genero as string,",
						"          estado_civil as string,",
						"          municipio as string",
						"     ),",
						"     useSchema: false,",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     format: 'delimited',",
						"     container: 'bronze-segip',",
						"     fileName: 'personas.csv',",
						"     columnDelimiter: ',',",
						"     escapeChar: '\\\\',",
						"     quoteChar: '\\\"',",
						"     columnNamesAsHeader: true) ~> sourceSegipPersonas",
						"sourceSegipPersonas sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     format: 'table',",
						"     store: 'sqlserver',",
						"     schemaName: 'bronce',",
						"     tableName: 'segip_personas',",
						"     insertable: true,",
						"     updateable: false,",
						"     deletable: false,",
						"     upsertable: false,",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError') ~> sinkSegipPersonas"
					]
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/LS_BlobStorage')]",
				"[concat(variables('factoryId'), '/linkedServices/LS_Destino_DWH')]"
			]
		}
	]
}