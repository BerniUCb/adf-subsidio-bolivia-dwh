{
	"name": "df_plata_sup_inscripciones",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sourceBronzeSupInscripciones"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sinkPlatasSupInscripciones"
				}
			],
			"transformations": [
				{
					"name": "limpiezaSupInscripciones"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce',",
				"     tableName: 'sup_inscripciones',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourceBronzeSupInscripciones",
				"sourceBronzeSupInscripciones derive(inscripcion_id = toInteger(inscripcion_id),",
				"          ci_beneficiaria = regexReplace(trim(ci_beneficiaria), '-', ''),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_inscripcion = toDate(fecha_inscripcion, 'yyyy-MM-dd'),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          estado = initCap(trim(estado))) ~> limpiezaSupInscripciones",
				"limpiezaSupInscripciones sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'plata',",
				"     tableName: 'sup_inscripciones',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkPlatasSupInscripciones"
			]
		}
	}
}