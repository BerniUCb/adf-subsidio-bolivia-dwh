{
	"name": "df_plata_sup_boletas",
	"properties": {
		"folder": {
			"name": "df_plata"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sourceBronzeSupBoletas"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sinkPlatasSupBoletas"
				}
			],
			"transformations": [
				{
					"name": "limpiezaSupBoletas"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce',",
				"     tableName: 'sup_boletas',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourceBronzeSupBoletas",
				"sourceBronzeSupBoletas derive(boleta_id = toInteger(boleta_id),",
				"          control_id = toInteger(control_id),",
				"          ci_beneficiaria = regexReplace(trim(ci_beneficiaria), '-', ''),",
				"          nro_boleta = trim(nro_boleta),",
				"          fecha_emision = coalesce(toDate(fecha_emision,'yyyy-MM-dd'), toDate(fecha_emision,'MM/dd/yyyy'), toDate(fecha_emision,'dd/MM/yyyy')),",
				"          estado = trim(upper(estado))) ~> limpiezaSupBoletas",
				"limpiezaSupBoletas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'plata',",
				"     tableName: 'sup_boletas',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkPlatasSupBoletas"
			]
		}
	}
}