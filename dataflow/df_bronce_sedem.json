{
	"name": "df_bronce_sedem",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "sourceSedemEmpresas"
				},
				{
					"name": "sourceSedemPlantas"
				},
				{
					"name": "sourceSedemProductos"
				},
				{
					"name": "sourceSedemProduccion"
				},
				{
					"name": "sourceSedemControlCalidad"
				},
				{
					"name": "sourceSedemInventario"
				}
			],
			"sinks": [
				{
					"name": "sinkSedemEmpresas"
				},
				{
					"name": "sinkSedemPlantas"
				},
				{
					"name": "sinkSedemProductos"
				},
				{
					"name": "sinkSedemProduccion"
				},
				{
					"name": "sinkSedemControlCalidad"
				},
				{
					"name": "sinkSedemInventario"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          empresa_id as string,",
				"          sigla as string,",
				"          nombre as string,",
				"          descripcion as string,",
				"          nit as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SEDEM',",
				"     fileName: 'empresas.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSedemEmpresas",
				"source(output(",
				"          planta_id as string,",
				"          empresa_id as string,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SEDEM',",
				"     fileName: 'plantas.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSedemPlantas",
				"source(output(",
				"          producto_id as string,",
				"          empresa_id as string,",
				"          nombre as string,",
				"          categoria as string,",
				"          presentacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SEDEM',",
				"     fileName: 'productos.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSedemProductos",
				"source(output(",
				"          produccion_id as string,",
				"          empresa_id as string,",
				"          planta_id as string,",
				"          producto_id as string,",
				"          nro_lote as string,",
				"          fecha_produccion as string,",
				"          cantidad as string,",
				"          unidad as string,",
				"          turno as string,",
				"          responsable as string,",
				"          costo_produccion as string,",
				"          estado as string,",
				"          fecha_vencimiento as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SEDEM',",
				"     fileName: 'produccion.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSedemProduccion",
				"source(output(",
				"          control_id as string,",
				"          produccion_id as string,",
				"          nro_lote as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          parametro as string,",
				"          valor_medido as string,",
				"          unidad_medida as string,",
				"          valor_minimo as string,",
				"          valor_maximo as string,",
				"          cumple as string,",
				"          inspector as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SEDEM',",
				"     fileName: 'control-calidad.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSedemControlCalidad",
				"source(output(",
				"          inventario_id as string,",
				"          empresa_id as string,",
				"          producto_id as string,",
				"          nro_lote as string,",
				"          cantidad_producida as string,",
				"          cantidad_despachada as string,",
				"          cantidad_disponible as string,",
				"          estado as string,",
				"          fecha_ultimo_movimiento as string,",
				"          almacen as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SEDEM',",
				"     fileName: 'inventario.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSedemInventario",
				"sourceSedemEmpresas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSedemEmpresas",
				"sourceSedemPlantas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSedemPlantas",
				"sourceSedemProductos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSedemProductos",
				"sourceSedemProduccion sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSedemProduccion",
				"sourceSedemControlCalidad sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSedemControlCalidad",
				"sourceSedemInventario sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSedemInventario"
			]
		}
	}
}