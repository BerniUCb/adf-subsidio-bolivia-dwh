				"     format: 'delimited',",
				"     container: 'bronze',",
				"     folderPath: 'SPL',",
				"     fileName: 'spl_afiliaciones.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSplAfiliaciones",
				"source(output(",
