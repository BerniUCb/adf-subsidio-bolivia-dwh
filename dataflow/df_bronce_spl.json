				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSplEmpleadores",
				"sourceSplAfiliaciones sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce',",
				"     tableName: 'spl_afiliaciones',",
