{
	"name": "df_bronce_bja",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "sourceBjaInscripciones"
				},
				{
					"name": "sourceBjaControlesPrenatales"
				},
				{
					"name": "sourceBjaPartos"
				},
				{
					"name": "sourceBjaControlesPediatricos"
				},
				{
					"name": "sourceBjaPagos"
				},
				{
					"name": "sourceBjaEstablecimientos"
				}
			],
			"sinks": [
				{
					"name": "sinkBjaInscripciones"
				},
				{
					"name": "sinkBjaControlesPrenatales"
				},
				{
					"name": "sinkBjaPartos"
				},
				{
					"name": "sinkBjaControlesPediatricos"
				},
				{
					"name": "sinkBjaPagos"
				},
				{
					"name": "sinkBjaEstablecimientos"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'BJA',",
				"     fileName: 'inscripciones.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceBjaInscripciones",
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'BJA',",
				"     fileName: 'controles-prenatales.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceBjaControlesPrenatales",
				"source(output(",
				"          parto_id as string,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as string,",
				"          fecha_parto as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as string,",
				"          talla_nacimiento_cm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'BJA',",
				"     fileName: 'partos.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceBjaPartos",
				"source(output(",
				"          control_pediatrico_id as string,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          peso_nino_kg as string,",
				"          talla_nino_cm as string,",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'BJA',",
				"     fileName: 'controles-pediatricos.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceBjaControlesPediatricos",
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'BJA',",
				"     fileName: 'pagos.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceBjaPagos",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'BJA',",
				"     fileName: 'establecimientos.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceBjaEstablecimientos",
				"sourceBjaInscripciones sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkBjaInscripciones",
				"sourceBjaControlesPrenatales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkBjaControlesPrenatales",
				"sourceBjaPartos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkBjaPartos",
				"sourceBjaControlesPediatricos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkBjaControlesPediatricos",
				"sourceBjaPagos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkBjaPagos",
				"sourceBjaEstablecimientos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkBjaEstablecimientos"
			]
		}
	}
}