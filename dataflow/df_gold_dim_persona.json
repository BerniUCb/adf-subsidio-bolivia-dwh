{
	"name": "df_gold_dim_persona",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sourcePlataSegipPersonas"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sinkGoldDimPersona"
				}
			],
			"transformations": [
				{
					"name": "ci"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as integer,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'plata',",
				"     tableName: 'segip_personas',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourcePlataSegipPersonas",
				"sourcePlataSegipPersonas aggregate(groupBy(ci),",
				"     nombres = first(nombres),",
				"          apellido_paterno = first(apellido_paterno),",
				"          apellido_materno = first(apellido_materno),",
				"          fecha_nacimiento = first(fecha_nacimiento),",
				"          genero = first(genero),",
				"          estado_civil = first(estado_civil),",
				"          profesion = first(profesion),",
				"          nivel_estudios = first(nivel_estudios),",
				"          municipio_residencia = first(municipio_residencia)) ~> ci",
				"ci sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'oro',",
				"     tableName: 'Dim_Persona',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkGoldDimPersona"
			]
		}
	}
}