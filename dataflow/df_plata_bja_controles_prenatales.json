{
	"name": "df_plata_bja_controles_prenatales",
	"properties": {
		"folder": {
			"name": "df_plata"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sourceBronzeBjaControlesPrenatales"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sinkPlatasBjaControlesPrenatales"
				}
			],
			"transformations": [
				{
					"name": "limpiezaBjaControlesPrenatales"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce',",
				"     tableName: 'bja_controles_prenatales',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourceBronzeBjaControlesPrenatales",
				"sourceBronzeBjaControlesPrenatales derive(control_prenatal_id = toInteger(control_prenatal_id),",
				"          ci_beneficiaria = regexReplace(trim(ci_beneficiaria), '-', ''),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          fecha_control = iif(isNull(fecha_control), toDate(null()), toDate(fecha_control, 'yyyy-MM-dd')),",
				"          semana_gestacion = iif(isNull(semana_gestacion), toInteger(null()), toInteger(semana_gestacion)),",
				"          peso_madre_kg = iif(isNull(peso_madre_kg), toDecimal(null()), toDecimal(peso_madre_kg, 5, 2)),",
				"          presion_arterial = iif(isNull(presion_arterial), toString(null()), trim(presion_arterial)),",
				"          resultado = iif(isNull(resultado), toString(null()), initCap(trim(resultado)))) ~> limpiezaBjaControlesPrenatales",
				"limpiezaBjaControlesPrenatales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'plata',",
				"     tableName: 'bja_controles_prenatales',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkPlatasBjaControlesPrenatales"
			]
		}
	}
}