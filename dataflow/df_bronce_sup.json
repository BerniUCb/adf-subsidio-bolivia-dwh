{
	"name": "df_bronce_sup",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "sourceSupInscripciones"
				},
				{
					"name": "sourceSupControles"
				},
				{
					"name": "sourceSupBoletas"
				},
				{
					"name": "sourceSupEntregas"
				},
				{
					"name": "sourceSupCatalogoPaquetes"
				},
				{
					"name": "sourceSupEstablecimientos"
				}
			],
			"sinks": [
				{
					"name": "sinkSupInscripciones"
				},
				{
					"name": "sinkSupControles"
				},
				{
					"name": "sinkSupBoletas"
				},
				{
					"name": "sinkSupEntregas"
				},
				{
					"name": "sinkSupCatalogoPaquetes"
				},
				{
					"name": "sinkSupEstablecimientos"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SUP',",
				"     fileName: 'inscripciones.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSupInscripciones",
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SUP',",
				"     fileName: 'controles.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSupControles",
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SUP',",
				"     fileName: 'boletas.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSupBoletas",
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SUP',",
				"     fileName: 'entregas.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSupEntregas",
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SUP',",
				"     fileName: 'catalogo-paquetes.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSupCatalogoPaquetes",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     container: 'bronze',",
				"     folderPath: 'SUP',",
				"     fileName: 'establecimientos.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceSupEstablecimientos",
				"sourceSupInscripciones sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSupInscripciones",
				"sourceSupControles sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSupControles",
				"sourceSupBoletas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSupBoletas",
				"sourceSupEntregas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSupEntregas",
				"sourceSupCatalogoPaquetes sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSupCatalogoPaquetes",
				"sourceSupEstablecimientos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce') ~> sinkSupEstablecimientos"
			]
		}
	}
}