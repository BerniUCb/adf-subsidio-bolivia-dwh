{
	"name": "df_plata_bja_establecimientos",
	"properties": {
		"folder": {
			"name": "df_plata"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sourceBronzeBjaEstablecimientos"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DWH",
						"type": "LinkedServiceReference"
					},
					"name": "sinkPlatasBjaEstablecimientos"
				}
			],
			"transformations": [
				{
					"name": "limpiezaBjaEstablecimientos"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronce',",
				"     tableName: 'bja_establecimientos',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourceBronzeBjaEstablecimientos",
				"sourceBronzeBjaEstablecimientos derive(establecimiento_id = toInteger(establecimiento_id),",
				"          codigo_snis = trim(upper(codigo_snis)),",
				"          nombre = initCap(trim(nombre)),",
				"          tipo = initCap(trim(tipo)),",
				"          nivel_atencion = initCap(trim(nivel_atencion)),",
				"          municipio = initCap(trim(municipio)),",
				"          departamento = initCap(trim(departamento)),",
				"          red_salud = iif(isNull(red_salud), toString(null()), initCap(trim(red_salud))),",
				"          estado = initCap(trim(estado))) ~> limpiezaBjaEstablecimientos",
				"limpiezaBjaEstablecimientos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'plata',",
				"     tableName: 'bja_establecimientos',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkPlatasBjaEstablecimientos"
			]
		}
	}
}